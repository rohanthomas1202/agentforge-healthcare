# === AgentForge Healthcare — Cloud Deployment (.env) ===
# Copy this file to .env and fill in your API keys.
# Used by docker-compose.cloud.yml

# === LLM API Keys ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# === LangSmith Observability ===
LANGCHAIN_API_KEY=lsv2_pt_...

# === OpenEMR OAuth2 Credentials ===
# These are set AFTER registering an OAuth client in OpenEMR (Step 7 in plan).
# The docker-compose.cloud.yml overrides BASE_URL/FHIR_URL/TOKEN_URL to use
# Docker internal DNS (https://openemr), so you only need client creds here.
OPENEMR_CLIENT_ID=your-cloud-client-id
OPENEMR_CLIENT_SECRET=your-cloud-client-secret
